{
    "uid": "ondc-mock-http",
    "title": "ONDC Mock — HTTP Requests",
    "tags": ["ondc", "mock-service", "http", "logs"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
        "list": [
            {
                "name": "service",
                "type": "textbox",
                "label": "service",
                "query": "ondc-playground-mock-service",
                "current": { "text": "ondc-playground-mock-service", "value": "ondc-playground-mock-service" }
            },
            {
                "name": "method",
                "type": "custom",
                "label": "method",
                "multi": true,
                "includeAll": true,
                "allValue": ".+",
                "query": "GET,POST,PUT,PATCH,DELETE",
                "current": { "text": "All", "value": "$__all" }
            },
            {
                "name": "status",
                "type": "textbox",
                "label": "status (regex, e.g. 2.. 4.. 5.. 404)",
                "query": ".*",
                "current": { "text": ".*", "value": ".*" }
            },
            {
                "name": "path",
                "type": "textbox",
                "label": "path (regex)",
                "query": ".*",
                "current": { "text": ".*", "value": ".*" }
            },
            {
                "name": "search",
                "type": "textbox",
                "label": "search (regex, on raw line incl. body)",
                "query": "",
                "current": { "text": "", "value": "" }
            }
        ]
    },
    "panels": [
        {
            "id": 1,
            "type": "stat",
            "title": "Requests in range (matching filter)",
            "datasource": { "type": "loki", "uid": "loki" },
            "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
            "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "loki", "uid": "loki" },
                    "expr": "sum(count_over_time({service=~\"$service\"} | json | event=\"response\" | http_method=~\"$method\" | http_path=~\"$path\" | http_status=~\"$status\" [$__range]))"
                }
            ]
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "Requests by status code",
            "datasource": { "type": "loki", "uid": "loki" },
            "gridPos": { "h": 5, "w": 18, "x": 6, "y": 0 },
            "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } }, "overrides": [] },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "loki", "uid": "loki" },
                    "expr": "sum by (http_status) (count_over_time({service=~\"$service\"} | json | event=\"response\" | http_method=~\"$method\" | http_path=~\"$path\" [$__rate_interval]))",
                    "legendFormat": "{{http_status}}"
                }
            ]
        },
        {
            "id": 3,
            "type": "logs",
            "title": "Requests — one line each (method · status · duration · path)",
            "description": "Always available (no body capture needed). Filter by status/method/path above; click a row to jump to its full body below via correlation_id (req=…).",
            "datasource": { "type": "loki", "uid": "loki" },
            "gridPos": { "h": 16, "w": 24, "x": 0, "y": 5 },
            "options": {
                "showTime": true,
                "showLabels": false,
                "showCommonLabels": false,
                "wrapLogMessage": true,
                "prettifyLogMessage": false,
                "enableLogDetails": true,
                "dedupStrategy": "none",
                "sortOrder": "Descending"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "loki", "uid": "loki" },
                    "expr": "{service=~\"$service\"} |~ \"(?i)$search\" | json | event=\"response\" | http_method=~\"$method\" | http_path=~\"$path\" | http_status=~\"$status\" | line_format `{{printf \"%-6s\" (.http_method | default \"?\")}} {{printf \"%-3s\" (.http_status | default \"?\")}} {{printf \"%6s\" (.http_duration_ms | default \"?\")}}ms  {{.http_path}}{{if .correlation_id}}  · req={{.correlation_id}}{{end}}`"
                }
            ]
        },
        {
            "id": 4,
            "type": "logs",
            "title": "Request / Response bodies + params — full JSON (pretty-printed)",
            "description": "Shows query params + request body + response body per request. Bodies are only present when OBS_LOG_BODIES includes `ingress` (e.g. OBS_LOG_BODIES=all); otherwise only method/path/status/query are shown. Redacted + capped at LOG_BODY_MAX_BYTES.",
            "datasource": { "type": "loki", "uid": "loki" },
            "gridPos": { "h": 20, "w": 24, "x": 0, "y": 21 },
            "options": {
                "showTime": true,
                "showLabels": false,
                "showCommonLabels": false,
                "wrapLogMessage": true,
                "prettifyLogMessage": true,
                "enableLogDetails": true,
                "dedupStrategy": "none",
                "sortOrder": "Descending"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": { "type": "loki", "uid": "loki" },
                    "expr": "{service=~\"$service\"} |~ \"(?i)$search\" | json | event=\"response\" | http_method=~\"$method\" | http_path=~\"$path\" | http_status=~\"$status\""
                }
            ]
        }
    ]
}
