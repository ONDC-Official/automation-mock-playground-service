NODE_ENV=development // required: development | production
PORT=3000
LOG_LEVEL=info

BASE_URL=http://playground-mock-service.local
API_SERVICE_URL=http://api-service.local
CONFIG_SERVICE_URL=http://config-service.local

REDIS_USERNAME=""
REDIS_HOST="localhost"
REDIS_PASSWORD=""
REDIS_PORT="6379"
REDIS_DB_0="0"
REDIS_DB_1="1"

RABBITMQ_URL=""
FINVU_AA_SERVICE_URL=http://finvu-aa-service.local
SKIP_MEETS_REQUIRMENTS
# ── Observability ────────────────────────────────────────────────────────────
# winston-loki ships logs to Loki when NODE_ENV=production and LOKI_HOST is set.
SERVICE_NAME=ondc-playground-mock-service
LOKI_HOST=http://localhost:3100
# Request/response body capture in logs: off | ingress | egress | all (default egress)
OBS_LOG_BODIES=egress
# Max bytes of a captured body before truncation (default 16384)
LOG_BODY_MAX_BYTES=16384
# Grafana (docker-compose.observability.yml)
GRAFANA_PORT=3005
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
